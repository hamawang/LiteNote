{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LiteNote",
  "version": "1.3.0",
  "identifier": "com.qiufeng.litenote",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "轻签",
        "width": 360,
        "height": 620,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "skipTaskbar": true,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "nsis": {
      "portable": true,
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  }
}
